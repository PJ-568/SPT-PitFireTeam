<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net472</TargetFramework>
        <OutputType>Library</OutputType>
        <RootNamespace>pitTeam.SAINAddon</RootNamespace>
        <AssemblyName>pitFireTeam.SAINAddon</AssemblyName>
        <Version>0.7.4</Version>
        <LangVersion>latest</LangVersion>
        <Nullable>enable</Nullable>
        <NoWarn>$(NoWarn);CS8600;CS8601;CS8602;CS8604;CS8618;CS8620;CS8625</NoWarn>
        <Deterministic>true</Deterministic>
        <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\client\pitFireTeam.csproj" />
    </ItemGroup>

    <ItemGroup>
        <Reference Include="BepInEx">
            <HintPath>..\client\libs\BepInEx.dll</HintPath>
        </Reference>
        <Reference Include="0Harmony">
            <HintPath>..\client\libs\0Harmony.dll</HintPath>
        </Reference>
        <Reference Include="Assembly-CSharp">
            <HintPath>..\client\libs\Assembly-CSharp.dll</HintPath>
        </Reference>
        <Reference Include="Comfort">
            <HintPath>..\client\libs\Comfort.dll</HintPath>
        </Reference>
        <Reference Include="DrakiaXYZ-BigBrain">
            <HintPath>..\client\libs\DrakiaXYZ-BigBrain.dll</HintPath>
        </Reference>
        <Reference Include="DissonanceVoip">
            <HintPath>..\client\libs\DissonanceVoip.dll</HintPath>
        </Reference>
        <Reference Include="SAIN">
            <HintPath>..\client\libs\SAIN.dll</HintPath>
        </Reference>
        <Reference Include="UnityEngine">
            <HintPath>..\client\libs\UnityEngine.dll</HintPath>
        </Reference>
        <Reference Include="UnityEngine.CoreModule">
            <HintPath>..\client\libs\UnityEngine.CoreModule.dll</HintPath>
        </Reference>
        <Reference Include="UnityEngine.AIModule">
            <HintPath>..\client\libs\UnityEngine.AIModule.dll</HintPath>
        </Reference>
        <Reference Include="UnityEngine.PhysicsModule">
            <HintPath>..\client\libs\UnityEngine.PhysicsModule.dll</HintPath>
        </Reference>
        <Reference Include="System" />
        <Reference Include="System.Core" />
    </ItemGroup>
</Project>
